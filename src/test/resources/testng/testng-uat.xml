<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Selenium-TestNG-Java-BDD" parallel="none" thread-count="4" verbose="1">
    <listeners>
        <listener class-name="com.seleniumproject.listeners.EnvironmentListener"/>
        <listener class-name="com.seleniumproject.listeners.ExtentReportListener"/>
    </listeners>
    
    <test name="UAT_Execution">
        <parameter name="scenario.file.loc" value="src/test/resources/features"/>
        <parameter name="txt.scenario.file.ext" value=".feature"/>
        <parameter name="step.provider.pkg" value="com.seleniumproject.steps"/>
        <parameter name="env.resources" value="src/test/resources/env/uat"/>

        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>

        <classes>
            <class name="com.seleniumproject.runner.CucumberTest"/>
        </classes>
    </test>
</suite>